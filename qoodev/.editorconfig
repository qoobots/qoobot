# EditorConfig for qoodev
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,json}]
indent_style = space
indent_size = 2

[*.{vue,html,css,scss}]
indent_style = space
indent_size = 2

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.{toml,cfg}]
indent_style = space
indent_size = 4

[*.{md,rst}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

[*.{xml,svg}]
indent_style = space
indent_size = 2

[*.{cpp,h,hpp,cc,cxx,hxx}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.{sh,bash}]
indent_style = space
indent_size = 2
