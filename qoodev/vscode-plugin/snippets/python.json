{
    "QooSkill Class": {
        "prefix": "qooskills",
        "body": [
            "import asyncio",
            "from qoobot_sdk.skill import QooSkill, SkillConfig, SkillState",
            "",
            "",
            "class ${1:MySkill}(QooSkill):",
            "    \"\"\"${2:Skill description}\"\"\"",
            "",
            "    def __init__(self, config: SkillConfig | None = None):",
            "        super().__init__(config or SkillConfig(name=\"${1:MySkill}\"))",
            "",
            "    async def setup(self) -> None:",
            "        \"\"\"Called once when skill is loaded.\"\"\"",
            "        ${3:pass}",
            "",
            "    async def loop(self) -> None:",
            "        \"\"\"Main skill loop — called repeatedly.\"\"\"",
            "        ${4:pass}",
            "",
            "    async def teardown(self) -> None:",
            "        \"\"\"Called when skill is unloaded.\"\"\"",
            "        ${5:pass}",
            "",
            "",
            "if __name__ == \"__main__\":",
            "    skill = ${1:MySkill}()",
            "    asyncio.run(skill.run())"
        ],
        "description": "Create a new QooSkill class with lifecycle methods"
    },
