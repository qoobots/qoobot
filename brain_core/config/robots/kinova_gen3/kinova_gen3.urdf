<?xml version="1.0"?>
<!-- kinova_gen3.urdf — Kinova Gen3 6-DOF Robot Arm URDF (simplified for Phase 1) -->
<robot name="kinova_gen3">
  <!-- Base link -->
  <link name="base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- 6 joints (stub) — full URDF loaded from Kinova official package in real deployment -->
  <!-- joint_1 through joint_6 with appropriate limits -->

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin rpy="0 0 0" xyz="0 0 0.15"/>
    <axis xyz="0 0 1"/>
    <limit effort="40" lower="-2.9" upper="2.9" velocity="1.4"/>
  </joint>
  <link name="link_1">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <mass value="0.3"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin rpy="0 0 0" xyz="0 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit effort="40" lower="-2.0" upper="2.0" velocity="1.4"/>
  </joint>
  <link name="link_2">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.15"/>
      <mass value="0.3"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin rpy="0 0 0" xyz="0 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit effort="30" lower="-2.0" upper="2.0" velocity="1.4"/>
  </joint>
  <link name="link_3">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.12"/>
      <mass value="0.2"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin rpy="0 0 0" xyz="0 0 0.2"/>
    <axis xyz="0 0 1"/>
    <limit effort="20" lower="-2.9" upper="2.9" velocity="1.4"/>
  </joint>
  <link name="link_4">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.08"/>
      <mass value="0.15"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin rpy="0 0 0" xyz="0 0 0.15"/>
    <axis xyz="0 1 0"/>
    <limit effort="15" lower="-2.0" upper="2.0" velocity="1.4"/>
  </joint>
  <link name="link_5">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.06"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin rpy="0 0 0" xyz="0 0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" lower="-2.9" upper="2.9" velocity="1.4"/>
  </joint>
  <link name="link_6">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <mass value="0.08"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Tool frame (end effector) -->
  <link name="tool0"/>
  <joint name="tool0_joint" type="fixed">
    <parent link="link_6"/>
    <child link="tool0"/>
    <origin rpy="0 0 0" xyz="0 0 0.08"/>
  </joint>
</robot>
