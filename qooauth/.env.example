# qooauth 环境变量配置

# 服务器
QOOAUTH_SERVER_PORT=8080
QOOAUTH_GRPC_PORT=9090
QOOAUTH_LOG_LEVEL=info
QOOAUTH_ENV=development

# 数据库
QOOAUTH_DATABASE_URL=postgres://qooauth:qooauth@localhost:5432/qooauth?sslmode=disable
QOOAUTH_DATABASE_MAX_CONNS=25
QOOAUTH_DATABASE_MIN_CONNS=5
QOOAUTH_DATABASE_MAX_IDLE_TIME=15m

# Redis
QOOAUTH_REDIS_URL=redis://localhost:6379/0
QOOAUTH_REDIS_POOL_SIZE=20

# JWT
QOOAUTH_JWT_PRIVATE_KEY_PATH=./deploy/secrets/jwt_private_key.pem
QOOAUTH_JWT_PUBLIC_KEY_PATH=./deploy/secrets/jwt_public_key.pem
QOOAUTH_JWT_ACCESS_TOKEN_TTL=1h
QOOAUTH_JWT_REFRESH_TOKEN_TTL=720h
QOOAUTH_JWT_ISSUER=https://auth.qoobot.com

# 密码策略
QOOAUTH_PASSWORD_MIN_LENGTH=8
QOOAUTH_PASSWORD_REQUIRE_UPPER=true
QOOAUTH_PASSWORD_REQUIRE_LOWER=true
QOOAUTH_PASSWORD_REQUIRE_DIGIT=true
QOOAUTH_PASSWORD_REQUIRE_SPECIAL=true
QOOAUTH_PASSWORD_MAX_FAILED_ATTEMPTS=5
QOOAUTH_PASSWORD_LOCK_DURATION=15m

# Argon2id
QOOAUTH_ARGON2_MEMORY=65536
QOOAUTH_ARGON2_ITERATIONS=3
QOOAUTH_ARGON2_PARALLELISM=4

# 速率限制
QOOAUTH_RATELIMIT_LOGIN=10/m
QOOAUTH_RATELIMIT_REGISTER=3/m
QOOAUTH_RATELIMIT_API=100/m

# CORS
QOOAUTH_CORS_ALLOWED_ORIGINS=https://auth.qoobot.com,https://console.qoobot.com
QOOAUTH_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# TOTP
QOOAUTH_TOTP_ISSUER=QooBot
QOOAUTH_TOTP_PERIOD=30

# OAuth
QOOAUTH_OAUTH_AUTHORIZATION_CODE_TTL=10m
QOOAUTH_OAUTH_ACCESS_TOKEN_TTL=1h
QOOAUTH_OAUTH_REFRESH_TOKEN_TTL=720h

# 会话
QOOAUTH_SESSION_MAX_DEVICES=10
QOOAUTH_SESSION_IDLE_TIMEOUT=72h
QOOAUTH_SESSION_ABSOLUTE_TIMEOUT=720h
