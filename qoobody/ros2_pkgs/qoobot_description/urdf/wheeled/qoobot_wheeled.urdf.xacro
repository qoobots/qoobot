<?xml version="1.0"?>
<!--
  ============================================================================
  QooBot Wheeled — 差速轮式移动底盘 URDF/Xacro 参考模型
  ============================================================================

  形态: 轮式移动底盘
  自由度: 6 DOF
    - 左驱动轮: 1 DOF (连续旋转)
    - 右驱动轮: 1 DOF (连续旋转)
    - 前万向轮: 2 DOF (旋转 + 转向)
    - 后万向轮: 2 DOF (旋转 + 转向)

  对标: unitree_ros-master robots/r1_description (R1 轮式机器人)
  兼容: ros2_control diff_drive_controller
  ============================================================================
-->
<robot name="qoobot_wheeled" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Materials -->
  <material name="chassis_gray">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.2 0.2 0.2 1"/>
  </material>

  <!-- Constants -->
  <xacro:property name="wheel_radius" value="0.1"/>     <!-- 100mm -->
  <xacro:property name="wheel_width" value="0.04"/>     <!-- 40mm -->
  <xacro:property name="wheel_separation" value="0.4"/>  <!-- 轮距 400mm -->
  <xacro:property name="chassis_length" value="0.6"/>
  <xacro:property name="chassis_width" value="0.4"/>
  <xacro:property name="chassis_height" value="0.15"/>

  <!-- ========================================================================
       MACRO: 驱动轮
       ======================================================================== -->
  <xacro:macro name="drive_wheel" params="prefix side x_sign">
    <joint name="${prefix}_wheel_${side}_joint" type="continuous">
      <origin xyz="${x_sign * wheel_separation/2} 0 ${-wheel_radius}" rpy="0 0 0"/>
      <parent link="${prefix}_chassis"/>
      <child link="${prefix}_wheel_${side}"/>
      <axis xyz="0 1 0"/>
    </joint>
    <link name="${prefix}_wheel_${side}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="1.57 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- ========================================================================
       MACRO: 万向轮 (caster)
       ======================================================================== -->
  <xacro:macro name="caster_wheel" params="prefix position x y z">
    <joint name="${prefix}_caster_${position}_swivel" type="continuous">
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <parent link="${prefix}_chassis"/>
      <child link="${prefix}_caster_${position}_swivel_link"/>
      <axis xyz="0 0 1"/>
    </joint>
    <link name="${prefix}_caster_${position}_swivel_link">
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="${prefix}_caster_${position}_roll" type="continuous">
      <origin xyz="0 0 ${-0.05}" rpy="0 0 0"/>
      <parent link="${prefix}_caster_${position}_swivel_link"/>
      <child link="${prefix}_caster_${position}_wheel"/>
      <axis xyz="0 1 0"/>
    </joint>
    <link name="${prefix}_caster_${position}_wheel">
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
      </inertial>
      <visual>
        <geometry>
          <sphere radius="0.05"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="0.05"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- ========================================================================
       ASSEMBLY
       ======================================================================== -->

  <!-- Chassis -->
  <link name="chassis">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="15.0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.8"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="chassis_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- Drive Wheels -->
  <xacro:drive_wheel prefix="" side="left" x_sign="1"/>
  <xacro:drive_wheel prefix="" side="right" x_sign="-1"/>

  <!-- Caster Wheels -->
  <xacro:caster_wheel prefix="" position="front" x="0.2" y="0" z="-0.05"/>
  <xacro:caster_wheel prefix="" position="rear" x="-0.2" y="0" z="-0.05"/>

  <!-- IMU -->
  <gazebo reference="chassis">
    <sensor type="imu" name="imu_sensor">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
    </sensor>
  </gazebo>

</robot>
