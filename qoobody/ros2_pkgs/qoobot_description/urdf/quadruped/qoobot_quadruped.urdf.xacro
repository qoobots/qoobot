<?xml version="1.0"?>
<!--
  ============================================================================
  QooBot Quadruped — 四足机器人 URDF/Xacro 参考模型
  ============================================================================

  形态: 四足机器人
  自由度: 12 DOF (4腿 × 3关节)
    每条腿: hip_roll + hip_pitch + knee_pitch

  对标: unitree_ros-master robots/go2_description (Go2 四足)
  兼容: qoobody HAL 关节电机规范 (CANopen/EtherCAT)
  ============================================================================
-->
<robot name="qoobot_quadruped" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="body_gray">
    <color rgba="0.6 0.6 0.6 1"/>
  </material>
  <material name="leg_dark">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>

  <!-- 形态参数 -->
  <xacro:property name="body_length" value="0.5"/>
  <xacro:property name="body_width" value="0.2"/>
  <xacro:property name="body_height" value="0.08"/>
  <xacro:property name="hip_length" value="0.05"/>
  <xacro:property name="thigh_length" value="0.2"/>
  <xacro:property name="calf_length" value="0.2"/>
  <xacro:property name="hip_x" value="0.25"/>   <!-- 髋关节 X 偏移 -->
  <xacro:property name="hip_y" value="0.1"/>    <!-- 髋关节 Y 偏移 -->

  <!-- ========================================================================
       MACRO: 单腿 (3 DOF)
       ======================================================================== -->
  <xacro:macro name="quadruped_leg" params="prefix leg x_sign y_sign">
    <!-- Hip Roll (abduction/adduction) -->
    <joint name="${prefix}_${leg}_hip_roll" type="revolute">
      <origin xyz="${x_sign * hip_x} ${y_sign * hip_y} 0" rpy="0 0 0"/>
      <parent link="${prefix}_body"/>
      <child link="${prefix}_${leg}_hip_roll"/>
      <axis xyz="1 0 0"/>
      <limit lower="-0.8" upper="0.8" effort="50" velocity="21"/>
    </joint>
    <link name="${prefix}_${leg}_hip_roll">
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0003"/>
      </inertial>
      <visual>
        <geometry><cylinder radius="0.03" length="${hip_length}"/></geometry>
        <material name="leg_dark"/>
      </visual>
    </link>

    <!-- Hip Pitch -->
    <joint name="${prefix}_${leg}_hip_pitch" type="revolute">
      <origin xyz="0 ${y_sign * hip_length} 0" rpy="0 0 0"/>
      <parent link="${prefix}_${leg}_hip_roll"/>
      <child link="${prefix}_${leg}_thigh"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.8" upper="1.5" effort="80" velocity="21"/>
    </joint>
    <link name="${prefix}_${leg}_thigh">
      <inertial>
        <origin xyz="0 0 ${-thigh_length/2}" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 ${-thigh_length/2}" rpy="0 0 0"/>
        <geometry><box size="0.03 0.03 ${thigh_length}"/></geometry>
        <material name="leg_dark"/>
      </visual>
    </link>

    <!-- Knee Pitch -->
    <joint name="${prefix}_${leg}_knee" type="revolute">
      <origin xyz="0 0 ${-thigh_length}" rpy="0 0 0"/>
      <parent link="${prefix}_${leg}_thigh"/>
      <child link="${prefix}_${leg}_calf"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.5" upper="0" effort="80" velocity="21"/>
    </joint>
    <link name="${prefix}_${leg}_calf">
      <inertial>
        <origin xyz="0 0 ${-calf_length/2}" rpy="0 0 0"/>
        <mass value="0.6"/>
        <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0005"/>
      </inertial>
      <visual>
        <origin xyz="0 0 ${-calf_length/2}" rpy="0 0 0"/>
        <geometry><box size="0.025 0.025 ${calf_length}"/></geometry>
        <material name="leg_dark"/>
      </visual>
      <!-- Foot contact -->
      <collision>
        <origin xyz="0 0 ${-calf_length}" rpy="0 0 0"/>
        <geometry><sphere radius="0.02"/></geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- ========================================================================
       ASSEMBLY
       ======================================================================== -->

  <!-- Body -->
  <link name="body">
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.15"/>
    </inertial>
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="body_gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- 4 Legs: FR, FL, RR, RL -->
  <xacro:quadruped_leg prefix="" leg="FR" x_sign="1" y_sign="-1"/>
  <xacro:quadruped_leg prefix="" leg="FL" x_sign="1" y_sign="1"/>
  <xacro:quadruped_leg prefix="" leg="RR" x_sign="-1" y_sign="-1"/>
  <xacro:quadruped_leg prefix="" leg="RL" x_sign="-1" y_sign="1"/>

  <!-- IMU -->
  <gazebo reference="body">
    <sensor type="imu" name="imu_sensor">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
    </sensor>
  </gazebo>

</robot>
