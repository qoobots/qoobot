<?xml version="1.0" encoding="utf-8"?>
<!--
  Kinova Gen3 7-DOF Robot Arm + Robotiq 2F-85 Gripper
  SDF 1.9 Model for Gazebo Simulation
  
  Specifications:
  - Reach: 902 mm (with gripper)
  - Payload: 4.0 kg (mid-range continuous)
  - Mass: ~7.2 kg
  - Joints: 7 revolute (arm) + 2 prismatic (gripper)
  
  Geometry is simplified (cylinders/boxes) for simulation performance.
  Joint limits match real Kinova Gen3 specifications.
-->
<sdf version="1.9">
  <model name="kinova_gen3">

    <!-- ============================================================ -->
    <!-- LINK 0: base_link (fixed base) -->
    <!-- ============================================================ -->
    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.50</mass>
        <inertia>
          <ixx>0.003</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.003</iyy> <iyz>0.0</iyz>
          <izz>0.003</izz>
        </inertia>
      </inertial>
      <visual name="base_visual">
        <pose>0 0 0.075 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.35 1</ambient>
          <diffuse>0.3 0.3 0.35 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <collision name="base_collision">
        <pose>0 0 0.075 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- JOINT 1: base → shoulder (actuator 1, Z-axis rotation) -->
    <!-- ============================================================ -->
    <joint name="joint_1" type="revolute">
      <parent>base_link</parent>
      <child>shoulder_link</child>
      <pose>0 0 0.15 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
      <limit>
        <lower>-3.1416</lower>  <!-- ±180° -->
        <upper>3.1416</upper>
        <effort>40</effort>
        <velocity>1.4</velocity>
      </limit>
      <dynamics>
        <damping>0.5</damping>
        <friction>0.3</friction>
      </dynamics>
    </joint>

    <!-- ============================================================ -->
    <!-- LINK 1: shoulder_link -->
    <!-- ============================================================ -->
    <link name="shoulder_link">
      <inertial>
        <mass>1.20</mass>
        <inertia>
          <ixx>0.005</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.002</iyy> <iyz>0.0</iyz>
          <izz>0.005</izz>
        </inertia>
      </inertial>
      <visual name="shoulder_visual">
        <pose>0 0 0.10 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.065</radius>
            <length>0.20</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.4 0.4 0.45 1</ambient>
          <diffuse>0.4 0.4 0.45 1</diffuse>
        </material>
      </visual>
      <collision name="shoulder_collision">
        <pose>0 0 0.10 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.065</radius>
            <length>0.20</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- JOINT 2: shoulder → upper_arm (actuator 2, Y-axis) -->
    <!-- ============================================================ -->
    <joint name="joint_2" type="revolute">
      <parent>shoulder_link</parent>
      <child>upper_arm_link</child>
      <pose>0 0 0.20 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>-2.25</lower>   <!-- ±128.9° -->
        <upper>2.25</upper>
        <effort>40</effort>
        <velocity>1.4</velocity>
      </limit>
      <dynamics>
        <damping>0.5</damping>
        <friction>0.3</friction>
      </dynamics>
    </joint>

    <!-- ============================================================ -->
    <!-- LINK 2: upper_arm_link -->
    <!-- ============================================================ -->
    <link name="upper_arm_link">
      <inertial>
        <mass>1.00</mass>
        <pose>0 0 0.19 0 0 0</pose>
        <inertia>
          <ixx>0.012</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.001</iyy> <iyz>0.0</iyz>
          <izz>0.012</izz>
        </inertia>
      </inertial>
      <visual name="upper_arm_visual">
        <pose>0 0 0.19 0 0 0</pose>
        <geometry>
          <box>
            <size>0.08 0.08 0.38</size>
          </box>
        </geometry>
        <material>
          <ambient>0.45 0.45 0.5 1</ambient>
          <diffuse>0.45 0.45 0.5 1</diffuse>
        </material>
      </visual>
      <collision name="upper_arm_collision">
        <pose>0 0 0.19 0 0 0</pose>
        <geometry>
          <box>
            <size>0.08 0.08 0.38</size>
          </box>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- JOINT 3: upper_arm → forearm (actuator 3, Y-axis) -->
    <!-- ============================================================ -->
    <joint name="joint_3" type="revolute">
      <parent>upper_arm_link</parent>
      <child>forearm_link</child>
      <pose>0 0 0.38 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>-3.1416</lower>  <!-- ±180° -->
        <upper>3.1416</upper>
        <effort>20</effort>
        <velocity>1.5</velocity>
      </limit>
      <dynamics>
        <damping>0.4</damping>
        <friction>0.25</friction>
      </dynamics>
    </joint>

    <!-- ============================================================ -->
    <!-- LINK 3: forearm_link -->
    <!-- ============================================================ -->
    <link name="forearm_link">
      <inertial>
        <mass>0.85</mass>
        <pose>0 0 0.19 0 0 0</pose>
        <inertia>
          <ixx>0.010</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.001</iyy> <iyz>0.0</iyz>
          <izz>0.010</izz>
        </inertia>
      </inertial>
      <visual name="forearm_visual">
        <pose>0 0 0.19 0 0 0</pose>
        <geometry>
          <box>
            <size>0.07 0.07 0.38</size>
          </box>
        </geometry>
        <material>
          <ambient>0.45 0.45 0.5 1</ambient>
          <diffuse>0.45 0.45 0.5 1</diffuse>
        </material>
      </visual>
      <collision name="forearm_collision">
        <pose>0 0 0.19 0 0 0</pose>
        <geometry>
          <box>
            <size>0.07 0.07 0.38</size>
          </box>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- JOINT 4: forearm → wrist_1 (actuator 4, X-axis) -->
    <!-- ============================================================ -->
    <joint name="joint_4" type="revolute">
      <parent>forearm_link</parent>
      <child>wrist_1_link</child>
      <pose>0 0 0.38 0 0 0</pose>
      <axis>
        <xyz>1 0 0</xyz>
      </axis>
      <limit>
        <lower>-2.58</lower>   <!-- ±147.8° -->
        <upper>2.58</upper>
        <effort>10</effort>
        <velocity>1.6</velocity>
      </limit>
      <dynamics>
        <damping>0.3</damping>
        <friction>0.2</friction>
      </dynamics>
    </joint>

    <!-- ============================================================ -->
    <!-- LINK 4: wrist_1_link -->
    <!-- ============================================================ -->
    <link name="wrist_1_link">
      <inertial>
        <mass>0.30</mass>
        <pose>0 0 0.04 0 0 0</pose>
        <inertia>
          <ixx>0.0005</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.0005</iyy> <iyz>0.0</iyz>
          <izz>0.0003</izz>
        </inertia>
      </inertial>
      <visual name="wrist_1_visual">
        <pose>0 0 0.04 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.55 1</ambient>
          <diffuse>0.5 0.5 0.55 1</diffuse>
        </material>
      </visual>
      <collision name="wrist_1_collision">
        <pose>0 0 0.04 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- JOINT 5: wrist_1 → wrist_2 (actuator 5, Y-axis) -->
    <!-- ============================================================ -->
    <joint name="joint_5" type="revolute">
      <parent>wrist_1_link</parent>
      <child>wrist_2_link</child>
      <pose>0 0 0.08 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>-3.1416</lower>  <!-- ±180° -->
        <upper>3.1416</upper>
        <effort>10</effort>
        <velocity>2.0</velocity>
      </limit>
      <dynamics>
        <damping>0.2</damping>
        <friction>0.15</friction>
      </dynamics>
    </joint>

    <!-- ============================================================ -->
    <!-- LINK 5: wrist_2_link -->
    <!-- ============================================================ -->
    <link name="wrist_2_link">
      <inertial>
        <mass>0.25</mass>
        <pose>0 0 0.04 0 0 0</pose>
        <inertia>
          <ixx>0.0004</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.0004</iyy> <iyz>0.0</iyz>
          <izz>0.0002</izz>
        </inertia>
      </inertial>
      <visual name="wrist_2_visual">
        <pose>0 0 0.04 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.045</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.55 1</ambient>
          <diffuse>0.5 0.5 0.55 1</diffuse>
        </material>
      </visual>
      <collision name="wrist_2_collision">
        <pose>0 0 0.04 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.045</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- JOINT 6: wrist_2 → wrist_3 (actuator 6, X-axis) -->
    <!-- ============================================================ -->
    <joint name="joint_6" type="revolute">
      <parent>wrist_2_link</parent>
      <child>wrist_3_link</child>
      <pose>0 0 0.08 0 0 0</pose>
      <axis>
        <xyz>1 0 0</xyz>
      </axis>
      <limit>
        <lower>-2.10</lower>   <!-- ±120.3° -->
        <upper>2.10</upper>
        <effort>10</effort>
        <velocity>2.1</velocity>
      </limit>
      <dynamics>
        <damping>0.2</damping>
        <friction>0.15</friction>
      </dynamics>
    </joint>

    <!-- ============================================================ -->
    <!-- LINK 6: wrist_3_link -->
    <!-- ============================================================ -->
    <link name="wrist_3_link">
      <inertial>
        <mass>0.20</mass>
        <pose>0 0 0.035 0 0 0</pose>
        <inertia>
          <ixx>0.0003</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.0003</iyy> <iyz>0.0</iyz>
          <izz>0.00015</izz>
        </inertia>
      </inertial>
      <visual name="wrist_3_visual">
        <pose>0 0 0.035 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.07</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.55 1</ambient>
          <diffuse>0.5 0.5 0.55 1</diffuse>
        </material>
      </visual>
      <collision name="wrist_3_collision">
        <pose>0 0 0.035 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.07</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- JOINT 7: wrist_3 → ee_link (actuator 7, Z-axis) -->
    <!-- ============================================================ -->
    <joint name="joint_7" type="revolute">
      <parent>wrist_3_link</parent>
      <child>ee_link</child>
      <pose>0 0 0.07 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
      <limit>
        <lower>-3.1416</lower>  <!-- ±180° (infinite rotation capable) -->
        <upper>3.1416</upper>
        <effort>10</effort>
        <velocity>2.5</velocity>
      </limit>
      <dynamics>
        <damping>0.15</damping>
        <friction>0.1</friction>
      </dynamics>
    </joint>

    <!-- ============================================================ -->
    <!-- LINK 7: ee_link (end effector mount flange) -->
    <!-- ============================================================ -->
    <link name="ee_link">
      <inertial>
        <mass>0.10</mass>
        <inertia>
          <ixx>0.0001</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.0001</iyy> <iyz>0.0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <visual name="ee_visual">
        <geometry>
          <cylinder>
            <radius>0.03</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
      <collision name="ee_collision">
        <geometry>
          <cylinder>
            <radius>0.03</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- ROBOTIQ 2F-85 GRIPPER -->
    <!-- ============================================================ -->
    
    <!-- JOINT 8: ee_link → gripper_base (fixed) -->
    <joint name="gripper_base_joint" type="fixed">
      <parent>ee_link</parent>
      <child>gripper_base</child>
      <pose>0 0 0.02 0 0 0</pose>
    </joint>

    <link name="gripper_base">
      <inertial>
        <mass>0.30</mass>
        <inertia>
          <ixx>0.0002</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.0002</iyy> <iyz>0.0</iyz>
          <izz>0.0003</izz>
        </inertia>
      </inertial>
      <visual name="gripper_base_visual">
        <pose>0 0 0.025 0 0 0</pose>
        <geometry>
          <box>
            <size>0.06 0.08 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.35 0.35 0.35 1</ambient>
          <diffuse>0.35 0.35 0.35 1</diffuse>
        </material>
      </visual>
      <collision name="gripper_base_collision">
        <pose>0 0 0.025 0 0 0</pose>
        <geometry>
          <box>
            <size>0.06 0.08 0.05</size>
          </box>
        </geometry>
      </collision>
    </link>

    <!-- JOINT 9: gripper_base → finger_left (prismatic) -->
    <joint name="finger_left_joint" type="prismatic">
      <parent>gripper_base</parent>
      <child>finger_left</child>
      <pose>0 -0.025 0.07 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>0.0</lower>
        <upper>0.0425</upper>  <!-- 85mm stroke / 2 -->
        <effort>100</effort>
        <velocity>0.05</velocity>
      </limit>
    </joint>

    <link name="finger_left">
      <inertial>
        <mass>0.08</mass>
        <pose>0 -0.02 0 0 0 0</pose>
        <inertia>
          <ixx>0.00005</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.00005</iyy> <iyz>0.0</iyz>
          <izz>0.00005</izz>
        </inertia>
      </inertial>
      <visual name="finger_left_visual">
        <pose>0 -0.015 0.02 0 0 0</pose>
        <geometry>
          <box>
            <size>0.01 0.03 0.04</size>
          </box>
        </geometry>
        <material>
          <ambient>0.55 0.55 0.55 1</ambient>
          <diffuse>0.55 0.55 0.55 1</diffuse>
        </material>
      </visual>
      <collision name="finger_left_collision">
        <pose>0 -0.015 0.02 0 0 0</pose>
        <geometry>
          <box>
            <size>0.01 0.03 0.04</size>
          </box>
        </geometry>
      </collision>
    </link>

    <!-- JOINT 10: gripper_base → finger_right (prismatic) -->
    <joint name="finger_right_joint" type="prismatic">
      <parent>gripper_base</parent>
      <child>finger_right</child>
      <pose>0 0.025 0.07 0 0 0</pose>
      <axis>
        <xyz>0 -1 0</xyz>
      </axis>
      <limit>
        <lower>0.0</lower>
        <upper>0.0425</upper>  <!-- 85mm stroke / 2 -->
        <effort>100</effort>
        <velocity>0.05</velocity>
      </limit>
    </joint>

    <link name="finger_right">
      <inertial>
        <mass>0.08</mass>
        <pose>0 0.02 0 0 0 0</pose>
        <inertia>
          <ixx>0.00005</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.00005</iyy> <iyz>0.0</iyz>
          <izz>0.00005</izz>
        </inertia>
      </inertial>
      <visual name="finger_right_visual">
        <pose>0 0.015 0.02 0 0 0</pose>
        <geometry>
          <box>
            <size>0.01 0.03 0.04</size>
          </box>
        </geometry>
        <material>
          <ambient>0.55 0.55 0.55 1</ambient>
          <diffuse>0.55 0.55 0.55 1</diffuse>
        </material>
      </visual>
      <collision name="finger_right_collision">
        <pose>0 0.015 0.02 0 0 0</pose>
        <geometry>
          <box>
            <size>0.01 0.03 0.04</size>
          </box>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- GAZEBO PLUGINS -->
    <!-- ============================================================ -->

    <!-- Joint State Publisher -->
    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>/kinova_gen3</namespace>
        <remapping>~/joint_states:=/joint_states</remapping>
      </ros>
      <update_rate>100</update_rate>
      <joint_name>joint_1</joint_name>
      <joint_name>joint_2</joint_name>
      <joint_name>joint_3</joint_name>
      <joint_name>joint_4</joint_name>
      <joint_name>joint_5</joint_name>
      <joint_name>joint_6</joint_name>
      <joint_name>joint_7</joint_name>
      <joint_name>finger_left_joint</joint_name>
      <joint_name>finger_right_joint</joint_name>
    </plugin>

    <!-- Effort Controller for all arm joints -->
    <plugin name="arm_controller" filename="libgazebo_ros_effort_controller.so">
      <ros>
        <namespace>/kinova_gen3</namespace>
      </ros>
      <joint name="joint_1"/>
      <joint name="joint_2"/>
      <joint name="joint_3"/>
      <joint name="joint_4"/>
      <joint name="joint_5"/>
      <joint name="joint_6"/>
      <joint name="joint_7"/>
    </plugin>

    <!-- Effort Controller for gripper joints -->
    <plugin name="gripper_controller" filename="libgazebo_ros_effort_controller.so">
      <ros>
        <namespace>/kinova_gen3</namespace>
      </ros>
      <joint name="finger_left_joint"/>
      <joint name="finger_right_joint"/>
    </plugin>

    <!-- Contact Sensor on Gripper Fingers -->
    <plugin name="finger_left_contact" filename="libgazebo_ros_bumper.so">
      <ros>
        <namespace>/kinova_gen3</namespace>
      </ros>
      <frame_name>finger_left</frame_name>
    </plugin>

    <plugin name="finger_right_contact" filename="libgazebo_ros_bumper.so">
      <ros>
        <namespace>/kinova_gen3</namespace>
      </ros>
      <frame_name>finger_right</frame_name>
    </plugin>

    <!-- Force-Torque Sensor at Wrist -->
    <plugin name="wrist_ft_sensor" filename="libgazebo_ros_ft_sensor.so">
      <ros>
        <namespace>/kinova_gen3</namespace>
        <remapping>~/wrench:=/wrist_ft</remapping>
      </ros>
      <frame_name>wrist_3_link</frame_name>
    </plugin>

  </model>
</sdf>
