<?xml version="1.0" encoding="utf-8"?>
<!--
  TurtleBot 4 Mobile Robot
  SDF 1.9 Model for Gazebo Simulation
  
  Specifications:
  - Base: Create 3 (iRobot) mobile platform
  - Dimensions: 340 x 340 x 350 mm (L x W x H)
  - Weight: ~3.9 kg
  - Max speed: 0.31 m/s linear, 1.90 rad/s angular
  - Sensors: RPLIDAR A1M8 (360° 2D LiDAR), OAK-D (RGB+Depth camera), IMU (BMI160)
  
  Drive: differential drive (2 wheels + 2 casters)
-->
<sdf version="1.9">
  <model name="turtlebot4">

    <!-- ============================================================ -->
    <!-- LINK 0: base_footprint (ground projection) -->
    <!-- ============================================================ -->
    <link name="base_footprint"/>

    <!-- JOINT: base_footprint → base_link (fixed at chassis height) -->
    <joint name="base_footprint_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
      <pose>0 0 0.08 0 0 0</pose>
    </joint>

    <!-- ============================================================ -->
    <!-- LINK 1: base_link (chassis body) -->
    <!-- ============================================================ -->
    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>2.50</mass>
        <inertia>
          <ixx>0.05</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.05</iyy> <iyz>0.0</iyz>
          <izz>0.08</izz>
        </inertia>
      </inertial>
      <!-- Main chassis visual -->
      <visual name="chassis_visual">
        <pose>0 0 0.08 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.17</radius>
            <length>0.16</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.25 0.3 1</ambient>
          <diffuse>0.2 0.25 0.3 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <!-- Top plate visual -->
      <visual name="top_plate_visual">
        <pose>0 0 0.17 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.01</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.25 0.28 0.33 1</ambient>
          <diffuse>0.25 0.28 0.33 1</diffuse>
        </material>
      </visual>
      <!-- Chassis collision -->
      <collision name="chassis_collision">
        <pose>0 0 0.08 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.17</radius>
            <length>0.16</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- LEFT DRIVE WHEEL -->
    <!-- ============================================================ -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <pose>0 0.18 0.05 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>-1e9</lower>
        <upper>1e9</upper>
        <effort>10</effort>
        <velocity>3.0</velocity>
      </limit>
      <dynamics>
        <damping>0.01</damping>
        <friction>0.8</friction>
      </dynamics>
    </joint>

    <link name="left_wheel">
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.0003</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.0005</iyy> <iyz>0.0</iyz>
          <izz>0.0003</izz>
        </inertia>
      </inertial>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- RIGHT DRIVE WHEEL -->
    <!-- ============================================================ -->
    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <pose>0 -0.18 0.05 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>-1e9</lower>
        <upper>1e9</upper>
        <effort>10</effort>
        <velocity>3.0</velocity>
      </limit>
      <dynamics>
        <damping>0.01</damping>
        <friction>0.8</friction>
      </dynamics>
    </joint>

    <link name="right_wheel">
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.0003</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.0005</iyy> <iyz>0.0</iyz>
          <izz>0.0003</izz>
        </inertia>
      </inertial>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- FRONT CASTER WHEEL (passive) -->
    <!-- ============================================================ -->
    <joint name="front_caster_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_caster</child>
      <pose>0.14 0 0.03 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>-1e9</lower>
        <upper>1e9</upper>
      </limit>
    </joint>

    <link name="front_caster">
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00005</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.00005</iyy> <iyz>0.0</iyz>
          <izz>0.00005</izz>
        </inertia>
      </inertial>
      <visual name="front_caster_visual">
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      <collision name="front_caster_collision">
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- REAR CASTER WHEEL (passive) -->
    <!-- ============================================================ -->
    <joint name="rear_caster_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_caster</child>
      <pose>-0.14 0 0.03 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>-1e9</lower>
        <upper>1e9</upper>
      </limit>
    </joint>

    <link name="rear_caster">
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00005</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.00005</iyy> <iyz>0.0</iyz>
          <izz>0.00005</izz>
        </inertia>
      </inertial>
      <visual name="rear_caster_visual">
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      <collision name="rear_caster_collision">
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- SENSOR MOUNT (plate above chassis for LiDAR + camera) -->
    <!-- ============================================================ -->
    <link name="sensor_mount">
      <pose>0 0 0.18 0 0 0</pose>
      <inertial>
        <mass>0.10</mass>
        <inertia>
          <ixx>0.001</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.001</iyy> <iyz>0.0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="sensor_mount_visual">
        <geometry>
          <box>
            <size>0.12 0.12 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
      <collision name="sensor_mount_collision">
        <geometry>
          <box>
            <size>0.12 0.12 0.02</size>
          </box>
        </geometry>
      </collision>
    </link>

    <joint name="sensor_mount_joint" type="fixed">
      <parent>base_link</parent>
      <child>sensor_mount</child>
    </joint>

    <!-- ============================================================ -->
    <!-- RPLIDAR A1M8 (2D LiDAR, 360°) -->
    <!-- ============================================================ -->
    <link name="lidar_link">
      <pose>0 0 0.21 0 0 0</pose>
      <inertial>
        <mass>0.17</mass>
        <inertia>
          <ixx>0.0001</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.0001</iyy> <iyz>0.0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>sensor_mount</parent>
      <child>lidar_link</child>
      <pose>0 0 0.03 0 0 0</pose>
    </joint>

    <plugin name="rplidar" filename="libgazebo_ros_ray_sensor.so">
      <ros>
        <namespace>/turtlebot4</namespace>
        <remapping>~/out:=/scan</remapping>
      </ros>
      <update_rate>10</update_rate>
      <sensor>
        <name>lidar</name>
        <type>ray</type>
        <pose>0 0 0 0 0 0</pose>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.1416</min_angle>
              <max_angle>3.1416</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.15</min>
            <max>12.0</max>
            <resolution>0.001</resolution>
          </range>
        </ray>
      </sensor>
    </plugin>

    <!-- ============================================================ -->
    <!-- OAK-D RGB Camera (forward-facing) -->
    <!-- ============================================================ -->
    <link name="camera_link">
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.00001</iyy> <iyz>0.0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="camera_visual">
        <geometry>
          <box>
            <size>0.03 0.06 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent>sensor_mount</parent>
      <child>camera_link</child>
      <pose>0.14 0 0.02 0 0.2 0</pose>
    </joint>

    <!-- RGB Camera sensor -->
    <plugin name="oakd_rgb" filename="libgazebo_ros_camera.so">
      <ros>
        <namespace>/turtlebot4</namespace>
        <remapping>~/image_raw:=/camera/color/image_raw</remapping>
        <remapping>~/camera_info:=/camera/color/camera_info</remapping>
      </ros>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.211</horizontal_fov>  <!-- ~69.4° -->
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
    </plugin>

    <!-- Depth Camera sensor -->
    <plugin name="oakd_depth" filename="libgazebo_ros_depth_camera.so">
      <ros>
        <namespace>/turtlebot4</namespace>
        <remapping>~/image_raw:=/camera/depth/image_rect_raw</remapping>
        <remapping>~/camera_info:=/camera/depth/camera_info</remapping>
        <remapping>~/points:=/camera/depth/points</remapping>
      </ros>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.211</horizontal_fov>
        <image>
          <width>848</width>
          <height>480</height>
          <format>R_FLOAT32</format>
        </image>
        <clip>
          <near>0.3</near>
          <far>3.0</far>
        </clip>
      </camera>
    </plugin>

    <!-- ============================================================ -->
    <!-- IMU (BMI160) -->
    <!-- ============================================================ -->
    <link name="imu_link"/>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
      <pose>0 0 0.09 0 0 0</pose>
    </joint>

    <plugin name="bmi160_imu" filename="libgazebo_ros_imu_sensor.so">
      <ros>
        <namespace>/turtlebot4</namespace>
        <remapping>~/out:=/imu/data</remapping>
      </ros>
      <update_rate>200</update_rate>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.00017</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.00017</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.00017</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.002</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.002</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.002</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
    </plugin>

    <!-- ============================================================ -->
    <!-- DIFFERENTIAL DRIVE CONTROLLER -->
    <!-- ============================================================ -->
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/turtlebot4</namespace>
        <remapping>~/cmd_vel:=/cmd_vel</remapping>
        <remapping>~/odom:=/odom</remapping>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.36</wheel_separation>
      <wheel_diameter>0.10</wheel_diameter>
      <max_wheel_torque>5.0</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <odometry_source>world</odometry_source>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
    </plugin>

    <!-- ============================================================ -->
    <!-- JOINT STATE PUBLISHER -->
    <!-- ============================================================ -->
    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>/turtlebot4</namespace>
      </ros>
      <update_rate>50</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>front_caster_joint</joint_name>
      <joint_name>rear_caster_joint</joint_name>
    </plugin>

  </model>
</sdf>
