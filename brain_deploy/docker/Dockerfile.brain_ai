# brain_ai Docker 镜像
# 基础：Python 3.11 + Ubuntu 22.04
# 支持：CPU 推理（stub/llama.cpp）
# GPU 推理（TensorRT-LLM）需替换 FROM 行为 nvidia/cuda:12.2.0-devel-ubuntu22.04

FROM python:3.11-slim-bookworm

WORKDIR /workspace

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgrpc++-dev \
    libprotobuf-dev \
    protobuf-compiler-grpc \
    && rm -rf /var/lib/apt/lists/*

# 安装 Python 依赖
COPY pyproject.toml README.md ./
RUN pip install --no-cache-dir -e ".[ai]" || \
    pip install --no-cache-dir \
        grpcio>=1.59.0 \
        grpcio-tools>=1.59.0 \
        protobuf>=4.24.0 \
        websockets>=12.0 \
        pydantic>=2.5.0 \
        structlog>=23.2.0

# 复制源码（不含模型权重）
COPY brain_ai/ brain_ai/
COPY brain_proto/ brain_proto/

# 生成 Protobuf 存根（若已生成可跳过）
RUN if command -v buf &> /dev/null; then \
      bash brain_proto/scripts/buf_generate.sh; \
    fi

EXPOSE 50051 8765

HEALTHCHECK --interval=15s --timeout=5s --retries=5 \
  CMD python -c "import grpc; ch=grpc.insecure_channel('localhost:50051'); print('ok')" || exit 1

CMD ["python", "-m", "brain_ai.server", "--host", "0.0.0.0", "--port", "50051"]
